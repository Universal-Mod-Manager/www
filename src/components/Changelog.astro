---
import { Icon } from 'astro-icon/components';
import type { Release } from '~/lib/github';
import { URLS } from '~/data/site';

interface Props {
  release: Release | null;
  lang?: string;
  viewChangelogLabel?: string;
  noReleaseLabel?: string;
  followReleasesLabel?: string;
}

const {
  release,
  lang = 'en',
  viewChangelogLabel = 'View full changelog on GitHub',
  noReleaseLabel = 'No release published yet.',
  followReleasesLabel = 'Follow releases on GitHub',
} = Astro.props;

const dateLocale = lang === 'fr' ? 'fr-FR' : 'en-GB';
const date = release?.publishedAt
  ? new Date(release.publishedAt).toLocaleDateString(dateLocale, {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<div
  class="rounded-lg border p-6"
  style="background-color: var(--aw-color-bg-surface); border-color: var(--aw-color-border)"
>
  {
    release ? (
      <>
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <h3 class="text-lg font-semibold">{release.name}</h3>
          {date && <span class="text-sm text-muted">{date}</span>}
        </div>
        {release.body && (
          <pre class="mt-4 max-h-72 overflow-auto whitespace-pre-wrap text-sm text-muted">{release.body}</pre>
        )}
        <a
          href={release.url}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-1 text-sm text-primary hover:underline"
        >
          {viewChangelogLabel}
          <Icon name="tabler:external-link" class="h-4 w-4" />
        </a>
      </>
    ) : (
      <>
        <p class="text-muted">{noReleaseLabel}</p>
        <a
          href={URLS.releases}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-flex items-center gap-1 text-sm text-primary hover:underline"
        >
          {followReleasesLabel}
          <Icon name="tabler:external-link" class="h-4 w-4" />
        </a>
      </>
    )
  }
</div>
