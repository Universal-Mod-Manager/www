---
import { Icon } from 'astro-icon/components';
import type { Release } from '~/lib/github';
import { URLS } from '~/data/site';

interface Props {
  release: Release | null;
}

const { release } = Astro.props;

const date = release?.publishedAt
  ? new Date(release.publishedAt).toLocaleDateString('en-GB', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<div class="rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-slate-900">
  {
    release ? (
      <>
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <h3 class="text-lg font-semibold">{release.name}</h3>
          {date && <span class="text-sm text-muted">{date}</span>}
        </div>
        {release.body && (
          <pre class="mt-4 max-h-72 overflow-auto whitespace-pre-wrap text-sm text-muted">{release.body}</pre>
        )}
        <a
          href={release.url}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-1 text-sm text-primary hover:underline"
        >
          View full changelog on GitHub
          <Icon name="tabler:external-link" class="h-4 w-4" />
        </a>
      </>
    ) : (
      <>
        <p class="text-muted">No release published yet.</p>
        <a
          href={URLS.releases}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-flex items-center gap-1 text-sm text-primary hover:underline"
        >
          Follow releases on GitHub
          <Icon name="tabler:external-link" class="h-4 w-4" />
        </a>
      </>
    )
  }
</div>
