---
import '@fontsource-variable/inter';
---

<!--
  Bridge: the AstroWind / Tailwind components read `--aw-*` and `--ui-*`
  variables; we point those at the desktop `--umm-*` tokens defined in
  `~/assets/styles/umm/base.css` (and overridable by theme files). This is
  what makes the site adopt the desktop look without touching components.

  The desktop base theme is a single (light) palette, so `--aw-*` derives
  from the same `--umm-*` tokens regardless of the `.dark` class.
-->
<style is:inline>
  :root {
    --aw-font-sans: var(--umm-font);
    --aw-font-serif: var(--umm-font);
    --aw-font-heading: var(--umm-font);

    --aw-color-primary: var(--umm-primary);
    --aw-color-secondary: var(--umm-primary-hover);
    --aw-color-accent: var(--umm-primary);

    --aw-color-text-heading: var(--umm-text);
    --aw-color-text-default: var(--umm-text);
    --aw-color-text-muted: var(--umm-text-secondary);
    --aw-color-bg-page: var(--umm-bg);
    --aw-color-bg-page-dark: var(--umm-bg);

    --ui-radius: var(--umm-radius-md);
    --ui-btn-radius: var(--umm-radius-md);

    ::selection {
      background-color: var(--umm-primary-tint);
    }
  }
</style>
