---
import { THEMES, THEME_STORAGE_KEY, DEFAULT_THEME } from '~/data/themes';
---

<select
  data-theme-switcher
  aria-label="Theme"
  class="ml-1.5 cursor-pointer rounded-md border border-gray-200 bg-transparent px-2 py-1.5 text-sm text-muted focus:outline-none focus:ring-2 focus:ring-gray-200 dark:border-gray-700 dark:text-gray-400 dark:focus:ring-gray-700"
>
  {THEMES.map((theme) => <option value={theme.id}>{theme.label}</option>)}
</select>

<script is:inline define:vars={{ storageKey: THEME_STORAGE_KEY, fallback: DEFAULT_THEME }}>
  function initThemeSwitcher() {
    const select = document.querySelector('[data-theme-switcher]');
    if (!select) return;
    select.value = document.documentElement.dataset.theme || localStorage.getItem(storageKey) || fallback;
    select.addEventListener('change', () => {
      document.documentElement.dataset.theme = select.value;
      localStorage.setItem(storageKey, select.value);
    });
  }
  initThemeSwitcher();
  document.addEventListener('astro:after-swap', initThemeSwitcher);
</script>
