---
import { THEMES } from '~/data/themes';

const css = THEMES.filter((theme) => theme.css)
  .map((theme) => {
    const scope = `html[data-theme='${theme.id}']`;
    return theme.css
      .replace(/:root\b/g, scope)
      .replace(/^(body|html)\s*\{/gm, `${scope} $1 {`);
  })
  .join('\n');
---

<style is:inline set:html={css}></style>
