---
import { THEMES, THEME_STORAGE_KEY, DEFAULT_THEME } from '~/data/themes';

const ids = THEMES.map((theme) => theme.id);
---

<script is:inline define:vars={{ storageKey: THEME_STORAGE_KEY, fallback: DEFAULT_THEME, ids }}>
  function applyTheme() {
    const stored = localStorage.getItem(storageKey);
    document.documentElement.dataset.theme = stored && ids.includes(stored) ? stored : fallback;
  }
  applyTheme();
  document.addEventListener('astro:after-swap', applyTheme);
</script>
