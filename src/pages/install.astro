---
import Layout from '~/layouts/PageLayout.astro';
import Platforms from '~/components/widgets/Platforms.astro';
import DownloadButton from '~/components/DownloadButton.astro';

import { PLATFORMS, URLS } from '~/data/site';
import { getLatestRelease } from '~/lib/github';

const release = await getLatestRelease();

const metadata = {
  title: 'Install',
};
---

<Layout metadata={metadata}>
  <Platforms
    title="Install"
    subtitle="Grab the latest build, then follow the steps for your platform. All downloads come from the official GitHub releases page."
    columns={2}
    items={PLATFORMS}
  >
    <DownloadButton slot="actions" release={release} />

    Looking for older versions? Browse the
    <a href={URLS.releases} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">
      full release history on GitHub</a
    >.
  </Platforms>
</Layout>
