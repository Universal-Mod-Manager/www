---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';
import DownloadButton from '~/components/DownloadButton.astro';

import { PLATFORMS, URLS } from '~/data/site';
import { getLatestRelease } from '~/lib/github';

const release = await getLatestRelease();

const metadata = {
  title: 'Install',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="mb-8 text-center">
      <h1 class="text-4xl font-bold tracking-tight">Install</h1>
      <p class="mx-auto mt-3 max-w-2xl text-muted">
        Grab the latest build, then follow the steps for your platform. All downloads come from the official GitHub
        releases page.
      </p>
      <div class="mt-6 flex justify-center">
        <DownloadButton release={release} />
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {
        PLATFORMS.map((platform) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5 dark:border-gray-700 dark:bg-slate-900">
            <h2 class="flex items-center gap-2 text-lg font-semibold">
              <Icon name={platform.icon} class="h-5 w-5 text-primary" />
              {platform.name}
            </h2>
            <ol class="mt-3 list-decimal space-y-2 pl-5 text-sm text-muted">
              {platform.steps.map((step) => (
                <li>{step}</li>
              ))}
            </ol>
          </article>
        ))
      }
    </div>

    <p class="mt-8 text-center text-sm text-muted">
      Looking for older versions? Browse the
      <a href={URLS.releases} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">
        full release history on GitHub</a
      >.
    </p>
  </section>
</Layout>
