---
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import DownloadButton from '~/components/DownloadButton.astro';

import { FEATURES } from '~/data/site';
import { getLatestRelease } from '~/lib/github';

const release = await getLatestRelease();

const metadata = {
  title: 'Features',
};
---

<Layout metadata={metadata}>
  <Features2
    title="Features"
    subtitle="Everything Universal Mod Manager offers today, plus what's planned next."
    columns={3}
    items={[...FEATURES]}
  />

  <CallToAction title="Give it a try" subtitle="Grab the latest build and start managing your mods.">
    <div slot="actions" class="flex justify-center">
      <DownloadButton release={release} />
    </div>
  </CallToAction>
</Layout>
